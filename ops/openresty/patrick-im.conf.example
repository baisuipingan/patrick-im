server {
    listen 80;
    listen 443 ssl http2;
    server_name im.example.com;

    # 证书路径按你现有 1Panel/OpenResty 方式调整
    # include /usr/local/openresty/nginx/conf/ssl/root_ssl.conf;

    client_max_body_size 6g;

    location / {
        proxy_pass http://127.0.0.1:5800;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Browser relay uploads use S3 path-style presigned URLs:
    # https://im.example.com/<bucket>/<object>?X-Amz-...
    # Keep this bucket path ahead of the app fallback and stream uploads
    # directly to RustFS instead of buffering full multipart chunks in Nginx.
    location ^~ /patrick-im/ {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60s;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_max_temp_file_size 0;
    }
}
